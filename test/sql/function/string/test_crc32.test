# name: test/sql/function/string/crc32.test
# description: Test the crc32 function
# group: [string]

statement ok
PRAGMA enable_verification

query II
select crc32('hello'), crc32(NULL)
----
907060870
NULL

query I
select crc32('')
----
0

query I
select crc32('\xff\xff'::BLOB)
----
4294901760

query I
select crc32('The quick brown fox jumps over the lazy dog')
----
1095738169

statement ok
CREATE TABLE strings AS SELECT s::VARCHAR s FROM generate_series(0,10,1) t(s)

query II
select crc32(s), crc32('1') from strings ORDER BY s
----
